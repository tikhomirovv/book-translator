# Secrets and technical connection settings only.
# Application behavior lives in configs/config.yaml
# Copy to .env — loaded automatically on startup.

# OpenAI cloud (key required):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# LM Studio / local OpenAI-compatible server (key optional):
OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# Match the model id shown in LM Studio (or override via config.local.yaml):
# BOOK_TRANSLATOR_LLM_MODEL=your-model-id

# Optional: zerolog level
# LOG_LEVEL=info
